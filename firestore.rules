rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userRole() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : "editor";
    }

    function canWrite() {
      return signedIn() && (userRole() == "admin" || userRole() == "editor");
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && request.auth.uid == userId;
    }

    match /actions/{id} {
      allow read: if signedIn();
      allow create, update, delete: if canWrite();
    }

    match /points/{id} {
      allow read: if signedIn();
      allow create, update, delete: if canWrite();
    }

    match /locations/{id} {
      allow read: if signedIn();
      allow create, update, delete: if canWrite();
    }

    match /photos/{id} {
      allow read: if signedIn();
      allow create, update, delete: if canWrite();
    }

    match /history/{id} {
      allow read: if signedIn();
      allow create, update, delete: if canWrite();
    }

    match /notifications/{id} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if canWrite();
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /checklist_items/{id} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
